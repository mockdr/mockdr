meta {
  name: Search signals
  type: http
  seq: 1
}

post {
  url: {{kibana_base_url}}/api/detection_engine/signals/search
  body: json
  auth: none
}

headers {
  Authorization: ApiKey {{es_token}}
  kbn-xsrf: true
  Content-Type: application/json
}

body:json {
  {
    "query": {
      "bool": {
        "filter": [
          {
            "match": {
              "signal.status": "open"
            }
          }
        ]
      }
    },
    "size": 25
  }
}
