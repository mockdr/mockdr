meta {
  name: Update alert
  type: http
  seq: 3
}

patch {
  url: {{cs_base_url}}/alerts/entities/alerts/v3
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{cs_token}}
  Content-Type: application/json
}

body:json {
  {
    "action_parameters": [
      {
        "name": "update_status",
        "value": "in_progress"
      }
    ],
    "ids": ["{{cs_detection_id}}"]
  }
}
