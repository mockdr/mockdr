meta {
  name: Update incident
  type: http
  seq: 3
}

post {
  url: {{cs_base_url}}/incidents/entities/incident-actions/v1
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{cs_token}}
  Content-Type: application/json
}

body:json {
  {
    "action_parameters": [
      {
        "name": "update_status",
        "value": "20"
      }
    ],
    "ids": ["{{cs_incident_id}}"]
  }
}
