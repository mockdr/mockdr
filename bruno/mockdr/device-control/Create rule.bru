meta {
  name: Create rule
  type: http
  seq: 2
}

post {
  url: {{s1_base_url}}/device-control
  body: json
  auth: none
}

headers {
  Authorization: ApiToken {{s1_token}}
  Content-Type: application/json
}

body:json {
  {
    "data": {
      "ruleGroupName": "Block USB Storage",
      "action": "Block",
      "deviceClass": "Mass Storage",
      "status": "Enabled",
      "osType": "windows"
    }
  }
}
