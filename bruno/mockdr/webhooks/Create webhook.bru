meta {
  name: Create webhook subscription
  type: http
  seq: 2
}

post {
  url: {{base_url}}/webhooks
  body: json
  auth: none
}

headers {
  Authorization: ApiToken {{token}}
  Content-Type: application/json
}

body:json {
  {
    "url": "https://webhook.site/your-unique-id",
    "description": "SOAR integration test",
    "secret": "my-signing-secret-change-me",
    "event_types": ["threat.created", "threat.updated", "agent.offline"],
    "active": true
  }
}
