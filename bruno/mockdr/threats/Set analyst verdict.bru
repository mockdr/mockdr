meta {
  name: Set analyst verdict
  type: http
  seq: 3
}

post {
  url: {{base_url}}/threats/analyst-verdict
  body: json
  auth: none
}

headers {
  Authorization: ApiToken {{token}}
  Content-Type: application/json
}

body:json {
  {
    "data": {
      "analystVerdict": "true_positive"
    },
    "filter": {
      "ids": ["{{threat_id}}"]
    }
  }
}
