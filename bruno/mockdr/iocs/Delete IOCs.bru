meta {
  name: Delete IOCs
  type: http
  seq: 4
}

delete {
  url: {{s1_base_url}}/threat-intelligence/iocs
  body: json
  auth: none
}

headers {
  Authorization: ApiToken {{s1_token}}
  Content-Type: application/json
}

body:json {
  {
    "filter": {
      "uuids": ["replace-with-ioc-uuid"]
    }
  }
}
