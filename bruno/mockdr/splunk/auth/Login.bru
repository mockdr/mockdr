meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{splunk_base_url}}/services/auth/login
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  username: admin
  password: mockdr-admin
  output_mode: json
}

docs {
  Returns sessionKey — copy to splunk_session_key variable.
  Users: admin/mockdr-admin, analyst/mockdr-analyst, viewer/mockdr-viewer
}
