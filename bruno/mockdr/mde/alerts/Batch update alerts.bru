meta {
  name: Batch update alerts
  type: http
  seq: 4
}

post {
  url: {{mde_base_url}}/api/alerts/batchUpdate
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{mde_token}}
  Content-Type: application/json
}

body:json {
  {
    "alertIds": ["{{mde_alert_id}}"],
    "status": "Resolved",
    "assignedTo": "analyst@company.com",
    "classification": "TruePositive",
    "determination": "Malware"
  }
}
