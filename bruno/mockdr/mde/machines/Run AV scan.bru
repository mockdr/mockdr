meta {
  name: Run AV scan
  type: http
  seq: 7
}

post {
  url: {{mde_base_url}}/api/machines/{{mde_machine_id}}/runAntiVirusScan
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{mde_token}}
  Content-Type: application/json
}

body:json {
  {
    "Comment": "Triggered by SOAR",
    "ScanType": "Quick"
  }
}
