meta {
  name: Scan endpoint
  type: http
  seq: 4
}

post {
  url: {{xdr_base_url}}/endpoints/scan/
  body: json
  auth: none
}

headers {
  x-xdr-auth-id: {{xdr_auth_id}}
  x-xdr-nonce: {{xdr_nonce}}
  x-xdr-timestamp: {{xdr_timestamp}}
  Authorization: {{xdr_auth_header}}
  Content-Type: application/json
}

body:json {
  {
    "request_data": {
      "endpoint_id_list": ["{{xdr_endpoint_id}}"],
      "incident_id": "{{xdr_incident_id}}"
    }
  }
}
